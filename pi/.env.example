# Punchi Edge Agent — copy to pi/.env on the device and fill in.

# Orchestrator endpoints (Phase 2 backend)
ORCHESTRATOR_URL=http://localhost:3000
WS_URL=ws://localhost:3000/edge

# TODO: replace with the real Auth0 device token once Phase 2 device flow is implemented
AUTH0_DEVICE_TOKEN=MOCK_TOKEN_FOR_NOW

# TODO: drop PUNCHI_USER_ID once the orchestrator validates the bearer token instead
PUNCHI_USER_ID=

# Picovoice — get a key at https://console.picovoice.ai
PORCUPINE_ACCESS_KEY=
# Path to your "Hey Punchi" .ppn (custom keyword exported from Picovoice console).
# Leave blank to fall back to PORCUPINE_BUILTIN_KEYWORD for development.
PORCUPINE_KEYWORD_PATH=
PORCUPINE_BUILTIN_KEYWORD=computer

# VAD tuning — defaults work for a quiet room with the ReSpeaker mics.
SILENCE_RMS_THRESHOLD=500
SILENCE_TAIL_SECONDS=2.5
MAX_RECORDING_SECONDS=60
